{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-11B.json",
  "title": "NP_MNPCA-11B fill data",
  "type": "object",
  "properties": {
    "officer_N": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string",
          "description": "Printed name of an officer or director on a form whose row labels supply the capacity (so the widget captures only the name, not name+capacity). Distinct from MBCA-12's `officer_N.printed_name_and_capacity` where the widget combines both. Use the `_and_capacity` variant when the form has a single capacity-bearing widget; use `printed_name` when the form has separate Title and Name columns."
        },
        "address": {
          "type": "string",
          "description": "Single combined address widget for an officer/director (when the form has one address blank per row, not split into street + city_state_zip). Counterpart to MBCA-12's `officer_N.address.{street, city_state_zip}` split shape; pick whichever matches the form's widget composition."
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "signer_2": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string",
              "description": "Second signer's printed name and capacity on a form that provides two parallel signature blocks but is not a multi-party (merger) filing. Distinct from `merger.parties[N].signature_block.signer_N.*` (which is per-party). Use `filing.signer.*` for the first signer and `filing.signer_2.*` for the optional second signer to match form layout."
            }
          }
        },
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "revocation": {
      "type": "object",
      "properties": {
        "consent_source": {
          "type": "string",
          "description": "Indicates which body provided written consent to revoke voluntary dissolution under 13-B MRSA \u00a71102. Enum: 'members' | 'directors'. Specific to revocation-of-dissolution filings.",
          "enum": [
            "members",
            "directors"
          ]
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "officer_1": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "officer_2": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "officer_3": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "officer_4": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "officer_5": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "officer_6": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "officer_7": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "registered_agent": {
      "type": "object",
      "properties": {
        "physical_address": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "registered_agent",
    "revocation"
  ]
}
