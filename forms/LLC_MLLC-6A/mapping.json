    "Name of contact person": {
      "key": "filing.contact.name",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "(Name of contact person)"
    },
    "Daytime telephone number": {
      "key": "filing.contact.phone",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "(Daytime telephone number)"
    },
    "Contact email address for this filing": {
      "key": "filing.contact.email",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "(Contact email address for this filing)"
    },
    "Email address to use for annual report reminders": {
      "key": "entity.annual_report_reminder_email",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "(Email address to use for annual report reminders)"
    },
    "Name of attested copy recipient": {
      "key": "filing.attested_copy_recipient.name",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "(Name of attested copy recipient)"
    },
    "Firm or Company": {
      "key": "filing.attested_copy_recipient.firm",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "(Firm or Company)"
    },
    "Mailing Address": {
      "key": "filing.attested_copy_recipient.mailing_address.street",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "(Mailing Address)"
    },
    "City State  Zip": {
      "key": "filing.attested_copy_recipient.mailing_address.city_state_zip",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "(City, State & Zip)"
    },
    "Check Box14": {
      "key": "filing.expedited_service.hold_for_pickup",
      "field_type": "checkbox",
      "page": 2,
      "confidence": "high",
      "label": "Hold attested copy for pick up"
    },
    "Check Box15": {
      "key": "filing.expedited_service.expedite_24h",
      "field_type": "checkbox",
      "page": 2,
      "confidence": "high",
      "label": "24-hour expedited filing ($50)"
    },
    "Check Box16": {
      "key": "filing.expedited_service.immediate",
      "field_type": "checkbox",
      "page": 2,
      "confidence": "high",
      "label": "Immediate expedited filing ($100)"
    }
  }
