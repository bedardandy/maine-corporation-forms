{
  "form_id": "LLC_MLLC-6A",
  "map": {
    "name": {
      "key": "entity.name",
      "widgets": [
        "name",
        "new name"
      ],
      "field_type": "text",
      "page": 0,
      "confidence": "high",
      "label": "(Name of Limited Liability Company as it appears on the record of the Secretary of State)"
    },
    "original date": {
      "key": "entity.initial_formation_date",
      "field_type": "text",
      "page": 0,
      "confidence": "high",
      "label": "SECOND: The date of filing of the initial certificate of formation: ___"
    },
    "Check Box4": {
      "key": "entity.is_low_profit_llc",
      "field_type": "checkbox",
      "page": 0,
      "confidence": "high",
      "label": "THIRD: Designation as a low profit LLC (Check only if applicable): This is a low-profit limited liability company pursuant to 31 MRSA §1611..."
    },
    "Check Box5": {
      "key": "entity.is_professional_llc",
      "field_type": "checkbox",
      "page": 0,
      "confidence": "high",
      "label": "FOURTH: Designation as a professional limited liability company (Check only if applicable): This is a professional limited liability company* formed pursuant to 13 MRSA Chapter 22-A..."
    },
    "professional service": {
      "key": "entity.professional_services_description",
      "field_type": "text",
      "page": 0,
      "confidence": "high",
      "label": "(Type of professional services)",
      "when": "entity.is_professional_llc == true"
    },
    "Check Box7": {
      "key": "registered_agent.type",
      "widgets": [
        "Check Box7",
        "Check Box8"
      ],
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "FIFTH: The Registered Agent is a: [ ] Commercial Registered Agent"
    },
    "cra number": {
      "key": "registered_agent.cra_public_number",
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "CRA Public Number: ___",
      "when": "registered_agent.type == 'commercial'"
    },
    "agent": {
      "key": "registered_agent.name",
      "widgets": [
        "agent",
        "noncommercial agent"
      ],
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "(name of commercial registered agent)"
    },
    "physical": {
      "key": "registered_agent.physical_address",
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "(physical location, not P.O. Box – street, city, state and zip code)"
    },
    "mailing": {
      "key": "registered_agent.mailing_address",
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "(mailing address if different from above)"
    },
    "exhibit": {
      "key": "entity.restatement_amendments_exhibit_letter",
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "SEVENTH: Other matters the members determine to include are set forth in the attached Exhibit ___, and made a part hereof."
    },
    "dated": {
      "key": "filing.date_signed",
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "Dated: ___"
    },
    "name and capacity1": {
      "key": "authorized_person_1.printed_name_and_capacity",
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "(type or print name and capacity) [signer slot 1, paired with first signature line]"
    },
    "name and capacity2": {
      "key": "authorized_person_2.printed_name_and_capacity",
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "(type or print name and capacity) [signer slot 2]"
    },
    "name and capacity 3": {
      "key": "authorized_person_3.printed_name_and_capacity",
      "field_type": "text",
      "page": 1,
      "confidence": "high",
      "label": "(type or print name and capacity) [signer slot 3]"
    },
    "Name of entity": {
      "key": "filing.entities[0].name",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "Name of entity(s) on the submitted filings [1]"
    },
    "Name of entitys on the submitted filings 2": {
      "key": "filing.entities[1].name",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "Name of entity [2]"
    },
    "Total fees enclosed": {
      "key": "filing.total_fees_dollars",
      "field_type": "text",
      "page": 2,
      "confidence": "high",
      "label": "Total fee(s) enclosed: $"
