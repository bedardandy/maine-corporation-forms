{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-11E.json",
  "title": "NP_MNPCA-11E fill data",
  "type": "object",
  "properties": {
    "incorporator_N": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string",
          "description": "Combined printed-name-and-capacity for an incorporator-signature slot on forms whose signature-block caption reads '(type or print name and capacity)'. Extends the per-officer-signer-pattern (CORP_MBCA-6 / NP_MNPCA-6 use plain `incorporator_N.printed_name`) for forms like MNPCA-11E that explicitly capture capacity within the same widget. Same Shape D pattern as filing.signer.printed_name_and_capacity but scoped per role-keyed officer slot. The canonical capacity value will typically be 'Incorporator' but the form requires it typed."
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "original_articles_filing_date": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "registered_office": {
      "type": "object",
      "properties": {
        "address_line1": {
          "type": "string"
        },
        "address_line2": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "incorporator_1": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string"
        }
      }
    },
    "incorporator_2": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string"
        }
      }
    },
    "incorporator_3": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "incorporator_1",
    "registered_office"
  ]
}
