    },
    "dissociated_general_partner_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "dissociated_general_partner_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "dissociated_general_partner_3": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner_address_change_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "new_address": {
          "type": "string"
        }
      }
    },
    "general_partner_address_change_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "new_address": {
          "type": "string"
        }
      }
    },
    "general_partner_address_change_3": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "new_address": {
          "type": "string"
        }
      }
    },
    "general_partner_name_change_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "new_name": {
          "type": "string"
        }
      }
    },
    "general_partner_name_change_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "new_name": {
          "type": "string"
        }
      }
    },
    "general_partner_name_change_3": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "new_name": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "general_partner_1": {
      "type": "object",
      "properties": {
