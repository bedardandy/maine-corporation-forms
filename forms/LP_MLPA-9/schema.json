{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LP_MLPA-9.json",
  "title": "LP_MLPA-9 fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "initial_certificate_filing_date": {
          "type": "string",
          "description": "Date the limited partnership's initial certificate was filed (required on amendment forms)."
        },
        "is_lllp": {
          "type": "boolean",
          "description": "Boolean indicating whether the LP is a Limited Liability Limited Partnership (LLLP)."
        },
        "is_professional_lllp": {
          "type": "boolean",
          "description": "Boolean indicating whether the LLLP is a professional LLLP under 31 MRSA \u00a71354.4."
        },
        "is_dissolved": {
          "type": "boolean",
          "description": "Boolean indicating the limited partnership is dissolved (31 MRSA \u00a71393.2.A)."
        },
        "name": {
          "type": "string"
        },
        "professional_services_description": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "new_general_partner_N": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of a new general partner being added (indexed list)."
        },
        "address": {
          "type": "string",
          "description": "Address of a new general partner being added."
        }
      }
    },
    "new_general_partner": {
      "type": "object",
      "properties": {
        "additional_attached": {
          "type": "boolean",
          "description": "Boolean indicating an exhibit lists additional new general partners."
        },
        "additional_exhibit_letter": {
          "type": "string",
          "description": "Exhibit letter for additional new general partners."
        }
      }
    },
    "dissociated_general_partner_N": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of a general partner dissociating from the LP."
        },
        "address": {
          "type": "string",
          "description": "Address of a dissociating general partner."
        }
      }
    },
    "dissociated_general_partner": {
      "type": "object",
      "properties": {
        "additional_attached": {
          "type": "boolean",
          "description": "Boolean indicating an exhibit lists additional dissociated general partners."
        },
        "additional_exhibit_letter": {
          "type": "string",
          "description": "Exhibit letter for additional dissociated general partners."
        }
      }
    },
    "replacement_general_partner": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person admitted as GP after the last GP dissociated (31 MRSA \u00a71391.3.B)."
        },
        "physical_address": {
          "type": "string",
          "description": "Physical address of the replacement GP."
        },
        "mailing_address": {
          "type": "string",
          "description": "Optional mailing address of the replacement GP."
        }
      }
    },
    "winding_up_person": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person appointed to wind up the LP's activities (31 MRSA \u00a71393.3 or 4)."
        },
        "physical_address": {
          "type": "string",
          "description": "Physical address of the winding-up person."
        },
        "mailing_address": {
          "type": "string",
          "description": "Optional mailing address of the winding-up person."
        }
      }
    },
    "general_partner_address_change_N": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of a current GP whose address changed."
        },
        "new_address": {
          "type": "string",
          "description": "New address for a current GP."
        }
      }
    },
    "general_partner_address_change": {
      "type": "object",
      "properties": {
        "additional_attached": {
          "type": "boolean",
          "description": "Boolean indicating an exhibit lists additional address changes."
        },
        "additional_exhibit_letter": {
          "type": "string",
          "description": "Exhibit letter for additional address changes."
        }
      }
    },
    "general_partner_name_change_N": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Old name of a current GP whose name changed."
        },
        "new_name": {
          "type": "string",
          "description": "New name for a current GP."
        }
      }
    },
    "general_partner_name_change": {
      "type": "object",
      "properties": {
        "additional_attached": {
          "type": "boolean",
          "description": "Boolean indicating an exhibit lists additional name changes."
        },
        "additional_exhibit_letter": {
          "type": "string",
          "description": "Exhibit letter for additional name changes."
        }
      }
    },
    "amendment": {
      "type": "object",
      "properties": {
        "other_exhibit_letter": {
          "type": "string",
          "description": "Exhibit letter for other amendments (31 MRSA \u00a71322)."
        }
      }
    },
    "general_partner_N": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string",
          "description": "Printed name of an authorized signatory (individual)."
        }
      }
    },
    "general_partner_entity_N": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of an entity signatory."
        },
        "signer_printed_name_and_capacity": {
          "type": "string",
          "description": "Name and capacity of the natural person signing for an entity signatory."
        }
      }
    },
    "new_general_partner_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "new_general_partner_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "new_general_partner_3": {
