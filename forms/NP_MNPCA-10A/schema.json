{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-10A.json",
  "title": "NP_MNPCA-10A fill data",
  "type": "object",
  "properties": {
    "consolidation": {
      "type": "object",
      "properties": {
        "plan_exhibit_letter": {
          "type": "string",
          "description": "Letter of the exhibit containing the plan of consolidation (SECOND)."
        },
        "future_effective_date": {
          "type": "string",
          "description": "Optional future effective date for the consolidation; capped at 60 days post-filing per 13-B MRSA. Mirrors merger.future_effective_date."
        },
        "parties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "(A Maine Corporation) [first participating corporation name line at top of page]"
              },
              "vote_method": {
                "type": "string",
                "description": "[ ] By the members at a meeting on (date) ___ at which a quorum was present and such plan received at least a majority of the votes which members were entitled to cast."
              },
              "vote_method_date": {
                "type": "string",
                "description": "By the members at a meeting on (date) ___ [block 1 option 1 date]"
              },
              "signature_block": {
                "type": "object",
                "properties": {
                  "date_signed": {
                    "type": "string",
                    "description": "DATED ___ [first signature block date]"
                  },
                  "corporation_name": {
                    "type": "string",
                    "description": "(name of corporation) [first signature block]"
                  },
                  "signer_1": {
                    "type": "object",
                    "properties": {
                      "printed_name_and_capacity": {
                        "type": "string",
                        "description": "*By (signature) ___ / (type or print name and capacity) [first signature block, signer 1]"
                      }
                    }
                  },
                  "signer_2": {
                    "type": "object",
                    "properties": {
                      "printed_name_and_capacity": {
                        "type": "string",
                        "description": "*By (signature) ___ / (type or print name and capacity) [first signature block, signer 2]"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "registered_office": {
          "type": "object",
          "properties": {
            "address": {
              "type": "string",
              "description": "Single-line registered-office address (street, city, state, zip combined) for the new corporation resulting from the consolidation. Distinct from merger.surviving_corp.registered_office_address on NP_MNPCA-10 because consolidation produces a NEW entity rather than designating a survivor."
            }
          }
        },
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "consolidation",
    "entity"
  ]
}
