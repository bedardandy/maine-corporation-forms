{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LP_MLPA-1A.json",
  "title": "LP_MLPA-1A fill data",
  "type": "object",
  "properties": {
    "transferee": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person or entity receiving a transferred reserved name under 31 MRSA \u00a71309.1.C. New role prefix introduced by LP_MLPA-1A. Parallel to applicant.* (the transferor)."
        },
        "address": {
          "type": "string",
          "description": "Single combined-line mailing address of the transferee. Mirrors applicant.address shape on LP_MLPA-1."
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "applicant": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "printed_name_and_capacity": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "applicant",
    "entity",
    "filing",
    "transferee"
  ]
}
