{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LP_MLPA-12-1.json",
  "title": "LP_MLPA-12-1 fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "professional_services_description": {
          "type": "object",
          "properties": {
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            },
            "lineN": {
              "type": "string",
              "description": "Multi-line free-text description of professional services provided by a PLLLP (per the FOURTH paragraph footnote). 2 inline widgets on MLPA-12-1 (line1, line2). Same multi-line shape primitive as amendment.changes_description.lineN (MLPA-13A) \u2014 synth concatenates lines for the whole description; either may be empty."
            }
          }
        },
        "maine_assumed_name_for_suffix": {
          "type": "string"
        },
        "maine_fictitious_name": {
          "type": "string"
        },
        "is_lllp": {
          "type": "boolean"
        },
        "is_plllp": {
          "type": "boolean"
        },
        "formation_date_in_home_jurisdiction": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "principal_office": {
          "type": "object",
          "properties": {
            "physical_address": {
              "type": "string"
            },
            "mailing_address": {
              "type": "string"
            }
          }
        },
        "required_office": {
          "type": "object",
          "properties": {
            "physical_address": {
              "type": "string"
            },
            "mailing_address": {
              "type": "string"
            }
          }
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "fict4_accompanies": {
          "type": "string"
        }
      }
    },
    "registered_agent": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Whether the registered agent is a Commercial Registered Agent (CRA) or a Noncommercial Registered Agent. Enum: 'commercial' | 'noncommercial'.",
          "enum": [
            "commercial",
            "noncommercial"
          ]
        },
        "cra_public_number": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "physical_address": {
          "type": "string"
        },
        "mailing_address": {
          "type": "string"
        }
      }
    },
    "general_partner_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner_3": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner": {
      "type": "object",
      "properties": {
        "additional_attached": {
          "type": "string"
        },
        "additional_exhibit_letter": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "entity",
    "registered_agent"
  ]
}
