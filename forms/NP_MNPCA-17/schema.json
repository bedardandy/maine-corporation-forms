{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-17.json",
  "title": "NP_MNPCA-17 fill data",
  "type": "object",
  "properties": {
    "correction": {
      "type": "object",
      "properties": {
        "original_filing_date": {
          "type": "string",
          "description": "Date the original (now-being-corrected) document was filed with the SOS. Captured on Certificate of Correction filings (13-B/13-C MRSA \u00a7106.4 family)."
        },
        "original_document_title": {
          "type": "string",
          "description": "Title of the original document being corrected (e.g., 'Articles of Incorporation', 'Articles of Amendment'). Free-text per form caption '(i.e. Articles of Incorporation, Articles of Amendment, etc.)'."
        },
        "error_description": {
          "type": "string",
          "description": "Free-text description of the inaccuracy or defect being corrected. Required by 13-B MRSA \u00a7106.4 to identify what is being corrected before the corrected text is supplied."
        },
        "corrected_text": {
          "type": "string",
          "description": "Free-text block containing the corrected language in its entirety \u2014 the new text that replaces the erroneous portion of the original document."
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "registered_agent": {
      "type": "object",
      "properties": {
        "physical_address": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "signer_2": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "correction",
    "entity",
    "filing",
    "registered_agent"
  ]
}
