{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-10.json",
  "title": "NP_MNPCA-10 fill data",
  "type": "object",
  "properties": {
    "merger": {
      "type": "object",
      "properties": {
        "merging_corporations_recital": {
          "type": "string",
          "description": "Free-text recital of one or more merging Maine corporation names (the parties that merge into the survivor). For Maine/Maine nonprofit mergers this is a single combined widget — multi-corp scenarios use comma-separated or multi-line input."
        },
        "surviving_corporation_name": {
          "type": "string",
          "description": "Name of the surviving Maine corporation in a Maine/Maine nonprofit merger."
        },
        "plan_exhibit_letter": {
          "type": "string",
          "description": "Letter of the exhibit containing the plan of merger (SECOND)."
        },
        "surviving_corp": {
          "type": "object",
          "properties": {
            "registered_office_address_line1": {
              "type": "string",
              "description": "Two-line registered office address of the surviving corporation in Maine (FOURTH paragraph 1)."
            },
            "registered_office_address_line2": {
              "type": "string",
              "description": "Two-line registered office address of the surviving corporation in Maine (FOURTH paragraph 1)."
            }
          }
        },
        "merging_corp": {
          "type": "object",
          "properties": {
            "registered_office_address_line1": {
              "type": "string",
              "description": "Two-line registered office address of the merged corporation in Maine (FOURTH paragraph 2)."
            },
            "registered_office_address_line2": {
              "type": "string",
              "description": "Two-line registered office address of the merged corporation in Maine (FOURTH paragraph 2)."
            }
          }
        },
        "future_effective_date": {
          "type": "string"
        },
        "parties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "THIRD: As to each participating corporation: Name of Corporation (block 1)"
              },
              "vote_method": {
                "type": "string",
                "description": "Mutually-exclusive enum capturing how this constituent corporation adopted the plan of merger: 'majority_member_vote' | 'supermajority_member_vote' | 'written_consent_of_members' | 'board_of_directors_majority_vote' (block 1 / block 2 print the same four options).",
                "enum": [
                  "majority_member_vote",
                  "supermajority_member_vote",
                  "written_consent_of_members",
                  "board_of_directors_majority_vote"
                ]
              },
              "vote_method_date": {
                "type": "string",
                "description": "By the members at a meeting on (date) ___"
              },
              "signature_block": {
                "type": "object",
                "properties": {
                  "date_signed": {
                    "type": "string",
                    "description": "DATED ___ (surviving corp signature block)"
                  },
                  "corporation_name": {
                    "type": "string",
                    "description": "(surviving corporation) — corp-name underline next to DATED"
                  },
                  "signer_1": {
                    "type": "object",
                    "properties": {
                      "printed_name_and_capacity": {
                        "type": "string",
                        "description": "*By (signature) ___ / (type or print name and capacity) — surviving corp signer 1"
                      }
                    }
                  },
                  "signer_2": {
                    "type": "object",
                    "properties": {
                      "printed_name_and_capacity": {
                        "type": "string",
                        "description": "*By (signature) ___ / (type or print name and capacity) — surviving corp signer 2"
                      }
                    }
                  }
                }
              },
              "clerk_certification": {
                "type": "object",
                "properties": {
                  "corporation_name": {
                    "type": "string",
                    "description": "MUST BE COMPLETED FOR VOTE OF MEMBERS — (name of corporation)"
                  },
                  "signer_printed_name_and_title": {
                    "type": "string",
                    "description": "MUST BE COMPLETED FOR VOTE OF MEMBERS — (signature of clerk, secretary or asst. secretary)"
                  }
                }
              }
            }
          }
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "merger"
  ]
}
