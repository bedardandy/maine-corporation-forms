{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-11A.json",
  "title": "NP_MNPCA-11A fill data",
  "type": "object",
  "properties": {
    "dissolution": {
      "type": "object",
      "properties": {
        "total_voters": {
          "type": "string",
          "description": "Total number of members or directors entitled to vote on the dissolution resolution (whichever class is selected in SECOND). MNPCA-11A-specific because the parent NP_MNPCA-11 is a written-consent variant that has no vote-count widgets."
        },
        "votes_for": {
          "type": "string",
          "description": "Number of votes cast in favor of dissolution. May represent an inline single-class count or be conflated with dissolution.votes_for_total depending on which widget the user populates (the form has both a small per-class blank and a totals blank)."
        },
        "votes_for_total": {
          "type": "string",
          "description": "Totals row for 'votes for' on the THIRD vote-tally table. Sums dissolution.votes_for entries when the form is used to record a multi-class vote."
        },
        "votes_against": {
          "type": "string",
          "description": "Number of votes cast against dissolution."
        },
        "consent_class": {
          "type": "string",
          "description": "Enum capturing which class of constituents adopted the resolution attached as Exhibit A: 'members' (when the corporation has voting members) or 'directors_when_no_voting_members' (when there are no members or no members entitled to vote). Mutually exclusive (SECOND, \"'X' one box only\").",
          "enum": [
            "members",
            "directors_when_no_voting_members"
          ]
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "officer_president": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "officer_treasurer": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "officer_secretary": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "officer_clerk": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "director_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "director_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "director_3": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "registered_office": {
      "type": "object",
      "properties": {
        "address_line1": {
          "type": "string"
        },
        "address_line2": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "signer_1": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "signer_2": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "certification": {
      "type": "object",
      "properties": {
        "clerk_signature_printed_name": {
          "type": "string"
        },
        "clerk_signature": {
          "type": "string",
          "description": "MUST BE COMPLETED FOR VOTE OF MEMBERS - (signature of clerk, secretary or asst. secretary)"
        }
      }
    }
  },
  "required": [
    "dissolution",
    "entity",
    "filing",
    "registered_office"
  ]
}
