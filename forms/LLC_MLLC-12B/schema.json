{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LLC_MLLC-12B.json",
  "title": "LLC_MLLC-12B fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "post_cancellation_service_address": {
          "type": "object",
          "properties": {
            "{line1,line2}": {
              "type": "string",
              "description": "Two-line mailing address to which Maine SOS may forward service of process after a foreign LLC's qualification has been cancelled (per 31 MRSA \u00a71662, when the entity is not maintaining a registered agent in Maine). Distinct from registered_agent.* (no agent post-cancellation), entity.principal_office.* (the entity's actual operating address), and the \u00a7981-A-style SOS-as-agent appointment on merger filings (`merger.foreign_survivor.service_of_process_mailing_address`). Two physical widgets on the form, both labeled '(Principal office address)' \u2014 line1 typically holds the street, line2 typically holds city/state/zip."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            }
          }
        },
        "home_jurisdiction_name": {
          "type": "string"
        },
        "maine_fictitious_name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "formation_date_in_home_jurisdiction": {
          "type": "string"
        },
        "maine_authorization_date": {
          "type": "string"
        },
        "principal_office": {
          "type": "object",
          "properties": {
            "physical_address": {
              "type": "string"
            }
          }
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "entity",
    "filing"
  ]
}
