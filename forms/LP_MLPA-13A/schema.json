{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LP_MLPA-13A.json",
  "title": "LP_MLPA-13A fill data",
  "type": "object",
  "properties": {
    "filing": {
      "type": "object",
      "properties": {
        "original_annual_report_date": {
          "type": "string",
          "description": "Date the original annual report (the one being amended) was filed with the Secretary of State. Anchor for the \u00a71330.2 amendment window check (must be in the same filing year, between the original filing date and December 31st of that year)."
        },
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "amendment": {
      "type": "object",
      "properties": {
        "changes_description": {
          "type": "object",
          "properties": {
            "line{N}": {
              "type": "string",
              "description": "Multi-line text describing the substantive changes to the annual report. 8 inline widgets on MLPA-13A (line1\u2013line8); same shape primitive as upstream amendment.nature_and_text.line1\u2013line15 (NP_MNP-9). For overflow beyond 8 lines, the * footnote permits an attached additional page."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            },
            "line3": {
              "type": "string"
            },
            "line4": {
              "type": "string"
            },
            "line5": {
              "type": "string"
            },
            "line6": {
              "type": "string"
            },
            "line7": {
              "type": "string"
            },
            "line8": {
              "type": "string"
            }
          }
        },
        "effective_date": {
          "type": "string"
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "general_partner_1": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        }
      }
    },
    "general_partner_entity_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "signer_printed_name_and_capacity": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "amendment",
    "entity",
    "filing"
  ]
}
