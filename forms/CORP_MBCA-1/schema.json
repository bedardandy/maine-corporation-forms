{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-1.json",
  "title": "CORP_MBCA-1 fill data",
  "type": "object",
  "properties": {
    "name_reservation": {
      "type": "object",
      "properties": {
        "name_to_reserve": {
          "type": "string",
          "description": "The corporate/entity name the applicant wishes to reserve for 120 days."
        },
        "applicant": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Name of the person or entity reserving the name."
            },
            "address": {
              "type": "string",
              "description": "Address of the applicant; single-line on this form (no street/city/state/zip split)."
            },
            "printed_name_and_capacity": {
              "type": "string",
              "description": "Printed name and capacity (e.g., 'Jane Doe, Attorney') of the signing applicant."
            }
          }
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "filing",
    "name_reservation"
  ]
}
