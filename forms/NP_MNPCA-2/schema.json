{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-2.json",
  "title": "NP_MNPCA-2 fill data",
  "type": "object",
  "properties": {
    "filing": {
      "type": "object",
      "properties": {
        "application_type": {
          "type": "string",
          "description": "Whether this name-registration filing is a new registration or a renewal of a prior registration. Enum: 'new' | 'renewal'. Drives fee computation: new = $5/month \u00d7 months remaining in calendar year; renewal = $50 flat (per page-0 header).",
          "enum": [
            "new",
            "renewal"
          ]
        },
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "principal_office": {
          "type": "object",
          "properties": {
            "address_line{1,2}": {
              "type": "string",
              "description": "Two-line principal-office address layout \u2014 line 1 (wide) and line 2 (wide, labeled 'street, city, state and zip code'). Mirrors the registered_office.address_line{1,2} convention (NP_MNPCA-11/11A/11C) but scoped to entity.principal_office.* because the foreign corp's principal office is its home-jurisdiction principal place of business, not a Maine registered office. Distinct from CORP_MBCA-12A's single-line entity.principal_office.physical_address (which has only one widget)."
            },
            "address_line1": {
              "type": "string"
            },
            "address_line2": {
              "type": "string"
            }
          }
        },
        "home_jurisdiction_name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "formation_date_in_home_jurisdiction": {
          "type": "string"
        },
        "maine_business_purpose": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "entity",
    "filing"
  ]
}
