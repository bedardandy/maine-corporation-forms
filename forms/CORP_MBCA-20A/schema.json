{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-20A.json",
  "title": "CORP_MBCA-20A fill data",
  "type": "object",
  "properties": {
    "conversion": {
      "type": "object",
      "properties": {
        "new_jurisdiction": {
          "type": "string",
          "description": "The new (non-Maine) state or country of incorporation for the surviving entity following an outbound conversion. Use on charter-surrender filings where a Maine entity is leaving the jurisdiction. Distinct from entity.home_jurisdiction_name (which is for foreign entities filing INTO Maine)."
        },
        "future_effective_date": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "appraisal_rights_agent_mailing_address": {
          "type": "string",
          "description": "Forwarding mailing address provided to the Maine Secretary of State for SOS-as-agent service of process in shareholder-appraisal-rights actions under 13-C MRSA ch.13. Required on outbound conversions/charter-surrenders where Maine shareholders may still exercise appraisal rights against the now-foreign surviving entity."
        },
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "conversion",
    "entity",
    "filing"
  ]
}
