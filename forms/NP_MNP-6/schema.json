{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNP-6.json",
  "title": "NP_MNP-6 fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "location": {
          "type": "object",
          "properties": {
            "municipality": {
              "type": "string",
              "description": "Maine municipality where a domestic nonprofit corporation is located, per 13 MRSA \u00a7903 FOURTH recital. Used on older 'MNP-' forms that pre-date the registered-agent regime \u2014 modern 13-B MRSA forms (NP_MNPCA-6) capture location indirectly via registered_agent.physical_address."
            },
            "county": {
              "type": "string",
              "description": "Maine county where a domestic nonprofit corporation is located. Paired with entity.location.municipality on older MNP- forms."
            }
          }
        },
        "officers": {
          "type": "object",
          "properties": {
            "count": {
              "type": "integer",
              "description": "Number of initial officers declared on a formation filing (typically 4: President, VP, Secretary/Clerk, Treasurer). Captured as a free-text numeric field."
            },
            "president": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            },
            "vice_president": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            },
            "secretary_or_clerk": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            },
            "treasurer": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            }
          }
        },
        "contact_person": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Name of the on-record entity contact person (per 13 MRSA \u00a7903 SEVENTH). DISTINCT from filing.contact.name (cover-letter filing-correspondence contact). The entity.contact_person.* block is what NP_MNP-3 modifies via its contact_change.* keys \u2014 i.e., entity.contact_person.* is the persistent SOS-record contact while filing.contact.* is per-filing."
            },
            "mailing_address": {
              "type": "string",
              "description": "Mailing address of the on-record entity contact person (single combined widget \u2014 no street/city/state/zip split)."
            },
            "physical_address": {
              "type": "string",
              "description": "Physical address of the on-record entity contact person (single combined widget)."
            }
          }
        },
        "name": {
          "type": "string"
        },
        "nonprofit_type": {
          "type": "string"
        },
        "public_benefit_purpose": {
          "type": "string"
        },
        "mutual_benefit_purpose": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "director_N": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of an inline director or trustee slot on a formation filing (1-indexed). Subdivision of the officer_N.* roster pattern documented in 2026-04-30-officer-roster-pattern.md ('the pattern can be subdivided into director_N.* and officer_N.* without breaking the convention'). MNP-6 has 3 inline director slots; overflow goes to attached pages with no opt-in checkbox."
        }
      }
    },
    "director_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "director_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "director_3": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "incorporator_1": {
      "type": "object",
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        },
        "printed_name": {
          "type": "string"
        }
      }
    },
    "incorporator_2": {
      "type": "object",
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        },
        "printed_name": {
          "type": "string"
        }
      }
    },
    "incorporator_3": {
      "type": "object",
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        },
        "printed_name": {
          "type": "string"
        }
      }
    },
    "incorporator_4": {
      "type": "object",
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        },
        "printed_name": {
          "type": "string"
        }
      }
    },
    "incorporator_5": {
      "type": "object",
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        },
        "printed_name": {
          "type": "string"
        }
      }
    },
    "incorporator_6": {
      "type": "object",
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        },
        "printed_name": {
          "type": "string"
        }
      }
    },
    "incorporator_7": {
      "type": "object",
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "required": [
    "director_1",
    "entity",
    "filing"
  ]
}
