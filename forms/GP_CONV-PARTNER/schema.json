{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/GP_CONV-PARTNER.json",
  "title": "GP_CONV-PARTNER fill data",
  "type": "object",
  "properties": {
    "conversion": {
      "type": "object",
      "properties": {
        "new_entity": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "description": "Type of entity the partnership is converting into (radio enum). Enum: 'limited_partnership' | 'limited_liability_limited_partnership' | 'corporation' | 'limited_liability_company'. Distinct from MBCA-21's free-text conversion.new_entity.type because this form constrains the destination via a 4-checkbox radio.",
              "enum": [
                "limited_partnership",
                "limited_liability_limited_partnership",
                "corporation",
                "limited_liability_company"
              ]
            },
            "name": {
              "type": "string"
            }
          }
        },
        "future_effective_date": {
          "type": "string"
        },
        "new_entity_provisions_exhibit_letter": {
          "type": "string"
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "conversion",
    "entity",
    "filing"
  ]
}
