{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-1A.json",
  "title": "CORP_MBCA-1A fill data",
  "type": "object",
  "properties": {
    "name_reservation": {
      "type": "object",
      "properties": {
        "transferee": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Name of the person or entity receiving a previously reserved corporate name under 13-C MRSA \u00a7402.2. Lives in the name_reservation.* namespace (parallel to name_reservation.applicant.name) rather than a top-level transfer.* namespace, so all reservation-lifecycle keys cluster together."
            },
            "address": {
              "type": "string",
              "description": "Single-line address of the transferee (form does not split into street/city/state/zip). Parallel shape to MBCA-1's name_reservation.applicant.address."
            }
          }
        },
        "name_to_reserve": {
          "type": "string"
        },
        "applicant": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "filing",
    "name_reservation"
  ]
}
