{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LLC_MLLC-9.json",
  "title": "LLC_MLLC-9 fill data",
  "type": "object",
  "properties": {
    "amendment": {
      "type": "object",
      "properties": {
        "new_name": {
          "type": "string",
          "description": "Updated entity name proposed by the amendment (when changing). Form permits 'no change' as the value when there is no rename. Same shape primitive as upstream amendment.* keys; first appearance on a Maine LLC."
        },
        "other_changes_exhibit_letter": {
          "type": "string",
          "description": "Exhibit letter for catch-all amendments not covered by the named clauses (FIRST\u2013FIFTH on MLLC-9). Same shape as LP_MLPA-12A filing.other_amendments_exhibit_letter."
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "initial_filing_date": {
          "type": "string",
          "description": "Date the LLC's initial certificate of formation was filed with the Maine Secretary of State. Anchor for amendment-validity (initial filing must precede the amendment)."
        },
        "is_low_profit_llc": {
          "type": "boolean",
          "description": "Boolean elect-in for low-profit LLC status under 31 MRSA \u00a71611 (the four-prong qualification statements A\u2013D in \u00a71611 are recited inline on the form)."
        },
        "name": {
          "type": "string"
        },
        "is_professional_llc": {
          "type": "boolean"
        },
        "professional_services_description": {
          "type": "object",
          "properties": {
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            }
          }
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "registered_agent": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Whether the registered agent is a Commercial Registered Agent (CRA) or a Noncommercial Registered Agent. Enum: 'commercial' | 'noncommercial'.",
          "enum": [
            "commercial",
            "noncommercial"
          ]
        },
        "cra_public_number": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "physical_address": {
          "type": "string"
        },
        "mailing_address": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "authorized_person_1": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string"
        }
      }
    },
    "authorized_person_2": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "amendment",
    "authorized_person_1",
    "entity",
    "filing",
    "registered_agent"
  ]
}
