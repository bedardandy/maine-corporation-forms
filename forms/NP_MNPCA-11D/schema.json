{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-11D.json",
  "title": "NP_MNPCA-11D fill data",
  "type": "object",
  "properties": {
    "dissolution": {
      "type": "object",
      "properties": {
        "intent_filed_date": {
          "type": "string",
          "description": "Date the prior Statement of Intent to Dissolve (NP_MNPCA-11) was filed with the Secretary of State. The Articles of Dissolution must reference and post-date this filing under 13-B MRSA \u00a71104. Distinct from filing.date_signed."
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "registered_office": {
      "type": "object",
      "properties": {
        "address_line1": {
          "type": "string"
        },
        "address_line2": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer_1": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "signer_2": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "registered_office"
  ]
}
