{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LP_MLPA-12.json",
  "title": "LP_MLPA-12 fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "is_plllp": {
          "type": "boolean",
          "description": "Boolean indicating the foreign LP is a Professional Limited Liability Limited Partnership (PLLLP) qualified under 31 MRSA \u00a71354.4. Distinct from entity.is_lllp (PLLLP implies LLLP plus a profession). Same key as LP_MLPA-12-1, LP_MLPA-9. (Drafter originally proposed entity.is_professional_lllp; aligned to is_plllp here for consistency with prior pass-1 reviews.)"
        },
        "professional_services_description": {
          "type": "object",
          "properties": {
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            },
            "lineN": {
              "type": "string",
              "description": "Multi-line free-text description of professional services provided by a PLLLP (TENTH paragraph). 2 inline widgets on MLPA-12 (line1, line2). Same multi-line primitive as LP_MLPA-12-1 and LP_MLPA-13A's amendment.changes_description.lineN."
            }
          }
        },
        "home_jurisdiction_name": {
          "type": "string"
        },
        "maine_assumed_name_for_suffix": {
          "type": "string"
        },
        "maine_fictitious_name": {
          "type": "string"
        },
        "formation_date_in_home_jurisdiction": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "principal_office": {
          "type": "object",
          "properties": {
            "physical_address": {
              "type": "string"
            },
            "mailing_address": {
              "type": "string"
            }
          }
        },
        "required_office": {
          "type": "object",
          "properties": {
            "physical_address": {
              "type": "string"
            },
            "mailing_address": {
              "type": "string"
            }
          }
        },
        "is_lllp": {
          "type": "boolean"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "fict4_accompanies": {
          "type": "boolean",
          "description": "True when Form FICT-4 (fictitious name) accompanies this application \u2014 a single yes/this-applies checkbox, not an enum."
        },
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name": {
              "type": "string"
            }
          }
        },
        "signer_entity": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "signer_printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "registered_agent": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Whether the registered agent is a Commercial Registered Agent (CRA) or a Noncommercial Registered Agent. Enum: 'commercial' | 'noncommercial'.",
          "enum": [
            "commercial",
            "noncommercial"
          ]
        },
        "cra_public_number": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "physical_address": {
          "type": "string"
        },
        "mailing_address": {
          "type": "string"
        }
      }
    },
    "general_partner_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner_3": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner": {
      "type": "object",
      "properties": {
        "additional_attached": {
          "type": "boolean",
          "description": "Boolean opt-in indicating additional GPs are listed on a separate exhibit."
        },
        "additional_exhibit_letter": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "entity",
    "registered_agent"
  ]
}
