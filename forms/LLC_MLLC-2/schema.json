{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LLC_MLLC-2.json",
  "title": "LLC_MLLC-2 fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "certificate_of_existence_attached": {
          "type": "boolean",
          "description": "Boolean: whether a certificate of existence (or document of similar import) from the home jurisdiction, dated within 90 days, is physically attached to the filing. The page-0 FIFTH recital makes this mandatory but no AcroForm widget binds it — tracked as out-of-form metadata. Same gap as MLLP-2/MBCA-2."
        },
        "home_jurisdiction_name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "principal_office": {
          "type": "object",
          "properties": {
            "physical_address": {
              "type": "string"
            }
          }
        },
        "formation_date_in_home_jurisdiction": {
          "type": "string"
        },
        "business_purpose": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "application_type": {
          "type": "string",
          "description": "Whether this is a new registration or a renewal (FIRST: \"'X' one box only.\" — 'This application is for a [ ] new OR [ ] renewal of a registration of limited liability company name.'). Enum: 'new' | 'renewal'.",
          "enum": [
            "new",
            "renewal"
          ]
        },
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "entity",
    "filing"
  ]
}
