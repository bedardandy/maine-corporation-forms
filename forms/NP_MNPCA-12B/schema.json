{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-12B.json",
  "title": "NP_MNPCA-12B fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "maine_authorization_date": {
          "type": "string",
          "description": "Date a foreign entity was authorized to do business / carry on activities in Maine (i.e., the date Maine issued the certificate of authority following the original Application for Authority). Distinct from entity.formation_date_in_home_jurisdiction. Already established on CORP_MBCA-12B; re-affirmed here for the nonprofit counterpart."
        },
        "home_jurisdiction_name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "principal_office": {
          "type": "object",
          "properties": {
            "physical_address": {
              "type": "string"
            }
          }
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "withdrawal": {
      "type": "object",
      "properties": {
        "service_of_process_mailing_address": {
          "type": "string",
          "description": "Mailing address (combined street, city, state, zip in a single widget) to which the Secretary of State will mail a copy of any process served on the SOS for the corporation after surrender/withdrawal. Required by 13-B MRSA \u00a71208 (nonprofit) / 13-C MRSA \u00a71521 (business). Already established on CORP_MBCA-12B; this form re-uses the same key family rather than introducing a parallel entity.post_surrender_service_address namespace."
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "withdrawal"
  ]
}
