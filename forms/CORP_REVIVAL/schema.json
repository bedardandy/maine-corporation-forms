{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_REVIVAL.json",
  "title": "CORP_REVIVAL fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "original_filing_date": {
          "type": "string",
          "description": "Date the entity was originally filed/formed in Maine (pre-dissolution). Used by revival/restoration filings to identify the historical record. Distinct from `entity.formation_date_in_home_jurisdiction` (foreign-formation date)."
        },
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "revival": {
      "type": "object",
      "properties": {
        "entity_type": {
          "type": "string",
          "description": "Type of dissolved domestic entity being revived. Enum: 'domestic_nonprofit_corp' (13-B MRSA \u00a71117) | 'domestic_business_corp' (13-C MRSA \u00a71425) | 'domestic_llc' (31 MRSA \u00a71604) | 'domestic_lp' (31 MRSA \u00a71401-A). Drives both the governing statute citation and the base filing fee ($25 nonprofit, $150 other).",
          "enum": [
            "domestic_nonprofit_corp",
            "domestic_business_corp",
            "domestic_llc",
            "domestic_lp"
          ]
        },
        "clerk_at_dissolution": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Name of the clerk/registered agent appearing on the SOS record at the time of the entity's dissolution. Historical-record reference (not a current/new appointment, hence not under `clerk_change.*` or `registered_agent.*`)."
            },
            "address": {
              "type": "string",
              "description": "Single-line registered office address of the clerk/agent at the time of dissolution."
            }
          }
        },
        "purpose": {
          "type": "string",
          "description": "Free-text description of the purpose(s) for which revival is requested. Form provides four physical lines (Text5, Text8, Text11, Text10 in y order); fill-time concatenates with newline separators across all four widgets."
        },
        "time_period_needed": {
          "type": "string",
          "description": "Duration or end-date for the revival period (free text: e.g., 'two years' or 'through Dec 31, 2027'). Form does not constrain format."
        }
      }
    },
    "requesting_party_N": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string",
          "description": "Indexed roster (1..3) of parties requesting revival. Mirrors `incorporator_N.*` formation pattern."
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string",
              "description": "Street-line component of a requesting party's address."
            },
            "city_state_zip": {
              "type": "string",
              "description": "City/state/zip combined for a requesting party (form provides a single widget for this)."
            }
          }
        }
      }
    },
    "requesting_party_1": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        }
      }
    },
    "requesting_party_2": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        }
      }
    },
    "requesting_party_3": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "revival"
  ]
}
