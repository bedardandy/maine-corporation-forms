{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-12C.json",
  "title": "CORP_MBCA-12C fill data",
  "type": "object",
  "properties": {
    "transfer": {
      "type": "object",
      "properties": {
        "new_entity_type": {
          "type": "string",
          "description": "Enum identifying the destination entity type after a \u00a71524 transfer of authority. Values: 'foreign_nonprofit_corporation' | 'foreign_limited_partnership' | 'foreign_limited_liability_company' | 'foreign_limited_liability_partnership'. Drives which Application for Authority form must be bundled (MNPCA-12 / MLPA-12 / MLLC-12 / MLLP-12 respectively)."
        },
        "new_governing_jurisdiction": {
          "type": "string",
          "description": "State or country whose laws govern the entity's internal affairs after the \u00a71524 transfer. May or may not equal entity.home_jurisdiction depending on whether the conversion also re-domesticates to another jurisdiction."
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "home_jurisdiction_name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "maine_authorization_date": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "transfer"
  ]
}
