{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/NP_MNPCA-12-1.json",
  "title": "NP_MNPCA-12-1 fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "home_purpose": {
          "type": "object",
          "properties": {
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            }
          }
        },
        "maine_limited_activities": {
          "type": "object",
          "properties": {
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            }
          }
        },
        "home_jurisdiction_name": {
          "type": "string"
        },
        "maine_fictitious_name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "formation_date_in_home_jurisdiction": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "seeks_full_authority": {
          "type": "boolean",
          "description": "Boolean Yes/No election for whether the foreign nonprofit seeks authority for ALL activities authorized in its home jurisdiction and allowed by Maine law. When false, entity.maine_limited_activities must enumerate the limited scope. Specific to 13-B MRSA §1202 nonprofit foreign-authority filings; MLLC-12 (the LLC analogue under 31 MRSA) does not have a parallel election."
        },
        "fict4_accompanies": {
          "type": "string"
        }
      }
    },
    "registered_agent": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Whether the registered agent is a Commercial Registered Agent (CRA) or a Noncommercial Registered Agent. Enum: 'commercial' | 'noncommercial'.",
          "enum": [
            "commercial",
            "noncommercial"
          ]
        },
        "cra_public_number": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "physical_address": {
          "type": "string"
        },
        "mailing_address": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "entity",
    "registered_agent"
  ]
}
