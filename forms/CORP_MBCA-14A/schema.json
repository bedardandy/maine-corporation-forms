{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-14A.json",
  "title": "CORP_MBCA-14A fill data",
  "type": "object",
  "properties": {
    "resumption": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "description": "Method by which shareholders authorized the resumption of business under 13-C MRSA \u00a71621.5. Mutually-exclusive enum: 'meeting' (vote at a duly-called meeting) | 'written_consent' (written consent of shareholders)."
        },
        "meeting_date": {
          "type": "string",
          "description": "Date the shareholder meeting was held. Required when resumption.method='meeting'."
        },
        "meeting_location": {
          "type": "string",
          "description": "Location of the shareholder meeting. Required when resumption.method='meeting'."
        },
        "effective_date": {
          "type": "string",
          "description": "Optional effective date of the certificate of resumption \u2014 used only when the filer wants the resumption to take effect on a date OTHER than the filing date. Same key family is anticipated for any future resumption-style filings (e.g., MLLC-14B, MLPA-14, MNPCA equivalents)."
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "resumption"
  ]
}
