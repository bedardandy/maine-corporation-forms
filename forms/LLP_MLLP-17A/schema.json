{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LLP_MLLP-17A.json",
  "title": "LLP_MLLP-17A fill data",
  "type": "object",
  "properties": {
    "correction": {
      "type": "object",
      "properties": {
        "original_document_type": {
          "type": "string",
          "description": "Title/type of the original document being corrected (e.g., 'Application for Authority to do Business', 'Assumed Name'). On LLP_MLLP-17A this concept IS bound to a widget; on its domestic sibling LLP_MLLP-17 the analogous blank exists visually but has no AcroForm widget (upstream template difference)."
        },
        "original_filing_date": {
          "type": "string"
        },
        "defect_description": {
          "type": "string"
        },
        "corrected_text": {
          "type": "string"
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "home_jurisdiction_name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "signer_entity": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "signer_printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "correction",
    "entity",
    "filing"
  ]
}
