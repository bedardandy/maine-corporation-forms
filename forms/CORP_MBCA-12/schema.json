{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-12.json",
  "title": "CORP_MBCA-12 fill data",
  "type": "object",
  "properties": {
    "officer_N": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string",
          "description": "Indexed list of an existing entity's current officers/directors (combined name+capacity widget). Used by foreign-qualification filings (and other filings that recite an existing officer roster). Distinct from incorporator_N (formation-only) and from filing.signer.* (single authorized signer)."
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string",
              "description": "Officer's street or mailing address."
            },
            "city_state_zip": {
              "type": "string",
              "description": "Officer's city/state/zip combined (single widget)."
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "is_professional_corporation": {
          "type": "boolean"
        },
        "home_jurisdiction_name": {
          "type": "string"
        },
        "maine_fictitious_name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "formation_date_in_home_jurisdiction": {
          "type": "string"
        },
        "principal_office": {
          "type": "object",
          "properties": {
            "physical_address": {
              "type": "string"
            },
            "mailing_address": {
              "type": "string"
            }
          }
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "registered_agent": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Whether the registered agent is a Commercial Registered Agent (CRA) or a Noncommercial Registered Agent. Enum: 'commercial' | 'noncommercial'.",
          "enum": [
            "commercial",
            "noncommercial"
          ]
        },
        "cra_public_number": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "physical_address": {
          "type": "string"
        },
        "mailing_address": {
          "type": "string"
        }
      }
    },
    "officer_1": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        }
      }
    },
    "officer_2": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        }
      }
    },
    "officer_3": {
      "type": "object",
      "properties": {
        "printed_name_and_capacity": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city_state_zip": {
              "type": "string"
            }
          }
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "registered_agent"
  ]
}
