{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LLC_MLLC-5A.json",
  "title": "LLC_MLLC-5A fill data",
  "type": "object",
  "properties": {
    "filing": {
      "type": "object",
      "properties": {
        "signer_N": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string",
              "description": "Multi-slot extension of filing.signer.printed_name_and_capacity for forms that provide multiple parallel 'authorized person' signer blocks (N=1..2 inline on this form). Generic role-agnostic alternative to role-keyed multi-slot patterns like partner_N.* (LLP) and general_partner_N.* (LP); used when the form does not specify a particular role for the signer and any 'duly authorized' representative may sign. Same Shape-D primitive as filing.signer.printed_name_and_capacity."
            }
          }
        },
        "terminated_fictitious_name": {
          "type": "string"
        },
        "date_signed": {
          "type": "string"
        },
        "signer_1": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "signer_2": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "entity",
    "filing"
  ]
}
