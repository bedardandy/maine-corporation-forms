{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-11I.json",
  "title": "CORP_MBCA-11I fill data",
  "type": "object",
  "properties": {
    "dissolution": {
      "type": "object",
      "properties": {
        "early_dissolution_basis": {
          "type": "string",
          "description": "Enum identifying the statutory basis for dissolution under 13-C MRSA \u00a71401 (incorporator/initial-director dissolution): 'no_shares_issued' (\u00a71401.1) | 'not_commenced_business' (\u00a71401.2). Distinct from MBCA-11's dissolution.shareholder_approval_obtained (which records \u00a71404 shareholder-approved dissolution). Mutually exclusive \u2014 exactly one of the two FOURTH-recital checkboxes is selected per the form's 'X one box only' instruction."
        },
        "authorization_date": {
          "type": "string"
        },
        "effective_date": {
          "type": "string"
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "original_articles_filing_date": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer_1": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "signer_2": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "dissolution",
    "entity",
    "filing"
  ]
}
