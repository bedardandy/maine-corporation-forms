{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LLC_MLLC-17.json",
  "title": "LLC_MLLC-17 fill data",
  "type": "object",
  "properties": {
    "correction": {
      "type": "object",
      "properties": {
        "original_filing_date": {
          "type": "string",
          "description": "Date the original document being corrected was filed with the Secretary of State."
        },
        "original_document_name": {
          "type": "string",
          "description": "Title of the original document being corrected (e.g., 'Application for Authority to do Business', 'Statement of Assumed Name', 'Articles of Amendment')."
        },
        "error_description": {
          "type": "string",
          "description": "Free-text description of the incorrect or inaccurate information being corrected and the reason it is incorrect, or the manner in which the original signing was defective."
        },
        "corrected_information": {
          "type": "string",
          "description": "Free-text description of the correction \u2014 the new accurate information, or the corrected manner of signing."
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "signer_2": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string",
              "description": "Combined printed name and capacity of an optional second authorized signer (Shape D). Used on filings that provide two parallel signature blocks; numbering parallels the merger-form pattern (merger.parties[N].signature_block.signer_1/signer_2) but at the filing level."
            }
          }
        },
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "correction",
    "entity",
    "filing"
  ]
}
