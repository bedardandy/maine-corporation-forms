{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-21A.json",
  "title": "CORP_MBCA-21A fill data",
  "type": "object",
  "properties": {
    "conversion": {
      "type": "object",
      "properties": {
        "approval_type": {
          "type": "string",
          "description": "Source of organic-law approval for the entity conversion plan. Enum: 'domestic' (plan approved per the organic law of the domestic unincorporated entity) | 'foreign' (conversion approved per the organic law of the foreign unincorporated entity). MBCA-21A-specific because MBCA-21 has no analogous radio (it's domestic-corp-only).",
          "enum": [
            "domestic",
            "foreign"
          ]
        },
        "new_entity": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            }
          }
        },
        "new_entity_provisions_exhibit_letter": {
          "type": "string"
        },
        "future_effective_date": {
          "type": "string"
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "formation_date_in_home_jurisdiction": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "conversion",
    "entity",
    "filing"
  ]
}
