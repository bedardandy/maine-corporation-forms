{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-15.json",
  "title": "CORP_MBCA-15 fill data",
  "type": "object",
  "properties": {
    "indistinguishable_name": {
      "type": "object",
      "properties": {
        "proposed_name": {
          "type": "string",
          "description": "The specific name (indistinguishable from the consenting corporation's name) that the consenting corporation authorizes another applicant to use. New top-level namespace \u2014 not bound to entity.* because the name is being conferred OUT to a different applicant, not adopted by the consenting entity."
        },
        "requestor_name": {
          "type": "string",
          "description": "Name of the applicant entity that wishes to use the indistinguishable name. Distinct from filing.entities[0..1] because the requestor is not necessarily a filer on this form (it is a separately-filing entity whose own formation/name-reservation paperwork the consent supports)."
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "new_distinguishable_name": {
          "type": "string",
          "description": "The new distinguishable name the consenting corporation undertakes to adopt to resolve the indistinguishability. Lives under entity.* (not indistinguishable_name.*) because it modifies the consenting entity's own name."
        },
        "name": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "indistinguishable_name"
  ]
}
