{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LLP_MLLP-6.json",
  "title": "LLP_MLLP-6 fill data",
  "type": "object",
  "properties": {
    "entity": {
      "type": "object",
      "properties": {
        "is_professional_llp": {
          "type": "boolean",
          "description": "Boolean indicating the LLP is a professional limited liability partnership under 13 MRSA Chapter 22-A. LLP analog of MLPA-6's entity.is_professional_lllp (LP\u2192LLLP\u2192Professional-LLLP) but for LLP statute. Triggers naming and licensure requirements for the partnership."
        },
        "professional_services_description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "additional_provisions_exhibit_letter": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "contact_partner": {
      "type": "object",
      "properties": {
        "name_and_address": {
          "type": "string",
          "description": "Inline combined name+address widget for the FOURTH-recital contact partner. Parallels the split contact_partner.name / contact_partner.address widgets on the same form (Text9/Text10) \u2014 the form provides both representations as a redundant/alternative layout. Synth typically populates the split widgets and derives the combined widget at fill time as 'name, address'."
        },
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "partner_N": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string",
          "description": "Printed name of an individual partner signing the certificate (indexed 1..3 inline). Shape B variant (name only, no capacity field) of the multi-slot per-officer pattern \u2014 distinct from MLLP-6A's partner_N.printed_name_and_capacity (Shape D). Used on \u00a7822 LLP formation/qualification certificates where the role 'partner' is implicit and the form provides only '(type or print name)' captions."
        }
      }
    },
    "registered_agent": {
      "type": "object",
      "properties": {
        "cra_public_number": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Whether the registered agent is a Commercial Registered Agent (CRA) or a Noncommercial Registered Agent. Enum: 'commercial' | 'noncommercial'.",
          "enum": [
            "commercial",
            "noncommercial"
          ]
        },
        "name": {
          "type": "string"
        },
        "physical_address": {
          "type": "string"
        },
        "mailing_address": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "partner_1": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        }
      }
    },
    "partner_2": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        }
      }
    },
    "partner_3": {
      "type": "object",
      "properties": {
        "printed_name": {
          "type": "string"
        }
      }
    },
    "partner_entity_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "signer_printed_name_and_capacity": {
          "type": "string"
        }
      }
    },
    "partner_entity_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "signer_printed_name_and_capacity": {
          "type": "string"
        }
      }
    },
    "partner_entity_3": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "signer_printed_name_and_capacity": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "registered_agent"
  ]
}
