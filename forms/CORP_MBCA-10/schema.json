{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-10.json",
  "title": "CORP_MBCA-10 fill data",
  "type": "object",
  "properties": {
    "merger": {
      "type": "object",
      "properties": {
        "parties[N]": {
          "type": "object",
          "properties": {
            "recital": {
              "type": "string",
              "description": "Combined name | type of entity | jurisdiction | effective date for one party to a merger or share exchange (FIRST recital block on MBCA-10). Free-form string \u2014 form does not provide separate column widgets despite the four-column header label."
            },
            "signature_block": {
              "type": "object",
              "properties": {
                "name_and_type": {
                  "type": "string",
                  "description": "Combined party name + type of entity at the head of a per-party signature block on page 2."
                },
                "date_signed": {
                  "type": "string",
                  "description": "Date a specific party to the merger signed."
                },
                "signer_M": {
                  "type": "object",
                  "properties": {
                    "printed_name_and_capacity": {
                      "type": "string",
                      "description": "Printed name + capacity of one of (typically two) authorized signers for a party. Two signer slots per party because some entity types under 13-C \u00a71106.8 require two officer/manager signatures."
                    }
                  }
                }
              }
            }
          }
        },
        "additional_parties_attached": {
          "type": "boolean",
          "description": "Boolean opt-in indicating additional merger parties are attached on an exhibit (used when there are >4 parties)."
        },
        "additional_parties_exhibit_letter": {
          "type": "string",
          "description": "Letter of the exhibit containing additional-parties recital."
        },
        "surviving_entity": {
          "type": "object",
          "properties": {
            "name_and_jurisdiction": {
              "type": "string",
              "description": "Name and jurisdiction of incorporation of the surviving/acquiring entity (combined into one widget on this form despite a two-column header label)."
            },
            "principal_office": {
              "type": "object",
              "properties": {
                "physical_address": {
                  "type": "string",
                  "description": "Address of the surviving entity's principal place of business (where the executed plan of merger is on file). Single-line."
                },
                "mailing_address": {
                  "type": "string",
                  "description": "Optional mailing address for the surviving entity's principal place of business."
                }
              }
            }
          }
        },
        "fourth_election": {
          "type": "object",
          "properties": {
            "survivor_originating_doc_amended": {
              "type": "boolean",
              "description": "FOURTH option 1: If the originating document of the survivor of a merger is amended, the amendments are attached as Exhibit ___"
            },
            "new_corporation_created": {
              "type": "boolean",
              "description": "FOURTH option 2: If the result of the merger or share exchange creates a new corporation, attached is Exhibit ___ which contains all the provisions required..."
            }
          }
        },
        "survivor_amendments_exhibit_letter": {
          "type": "string",
          "description": "Exhibit letter for amendments to the surviving entity's originating document (FOURTH option 1)."
        },
        "new_corporation_provisions_exhibit_letter": {
          "type": "string",
          "description": "Exhibit letter for provisions required in a newly-created corporation's public organic document (FOURTH option 2)."
        },
        "future_effective_date": {
          "type": "string",
          "description": "Optional future effective date for the merger or share exchange. If blank, the filing date applies."
        },
        "sixth_election": {
          "type": "object",
          "properties": {
            "shareholder_approval_obtained": {
              "type": "boolean",
              "description": "SIXTH option 1: The plan was duly approved by the shareholders and, if voting by any separate voting group was required, by each separate group..."
            },
            "shareholder_approval_not_required": {
              "type": "boolean",
              "description": "SIXTH option 2: The plan of merger or share exchange did not require approval by the shareholders."
            }
          }
        },
        "seventh_election": {
          "type": "object",
          "properties": {
            "foreign_corp_authorized": {
              "type": "boolean",
              "description": "SEVENTH option 1: The participation of the foreign corporation was duly authorized as required by the organic law of the corporation."
            },
            "eligible_entity_authorized": {
              "type": "boolean",
              "description": "SEVENTH option 2: The participation of the eligible entity was duly authorized as required by the organic law of that entity."
            }
          }
        },
        "foreign_survivor": {
          "type": "object",
          "properties": {
            "service_of_process_mailing_address": {
              "type": "string",
              "description": "Mailing address to which the Maine Secretary of State may mail process served on the SOS as agent for a foreign-survivor entity (EIGHTH paragraph appointment under \u00a71106)."
            }
          }
        },
        "parties[0]": {
          "type": "object",
          "properties": {
            "recital": {
              "type": "string"
            },
            "signature_block": {
              "type": "object",
              "properties": {
                "name_and_type": {
                  "type": "string"
                },
                "date_signed": {
                  "type": "string"
                },
                "signer_1": {
                  "type": "object",
                  "properties": {
                    "printed_name_and_capacity": {
                      "type": "string"
                    }
                  }
                },
                "signer_2": {
                  "type": "object",
                  "properties": {
                    "printed_name_and_capacity": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "parties[1]": {
          "type": "object",
          "properties": {
            "recital": {
              "type": "string"
            },
            "signature_block": {
              "type": "object",
              "properties": {
                "name_and_type": {
                  "type": "string"
                },
                "date_signed": {
                  "type": "string"
                },
                "signer_1": {
                  "type": "object",
                  "properties": {
                    "printed_name_and_capacity": {
                      "type": "string"
                    }
                  }
                },
                "signer_2": {
                  "type": "object",
                  "properties": {
                    "printed_name_and_capacity": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "parties[2]": {
          "type": "object",
          "properties": {
            "recital": {
              "type": "string"
            },
            "signature_block": {
              "type": "object",
              "properties": {
                "name_and_type": {
                  "type": "string"
                },
                "date_signed": {
                  "type": "string"
                },
                "signer_1": {
                  "type": "object",
                  "properties": {
                    "printed_name_and_capacity": {
                      "type": "string"
                    }
                  }
                },
                "signer_2": {
                  "type": "object",
                  "properties": {
                    "printed_name_and_capacity": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "parties[3]": {
          "type": "object",
          "properties": {
            "recital": {
              "type": "string"
            }
          }
        },
        "parties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "recital": {
                "type": "string",
                "description": "FIRST: party row 1 (Name | Type of Entity | Jurisdiction | Date)"
              },
              "signature_block": {
                "type": "object",
                "properties": {
                  "name_and_type": {
                    "type": "string",
                    "description": "Must Be Completed By the First Party to the Merger: (Name and type of participating business entity)"
                  },
                  "date_signed": {
                    "type": "string",
                    "description": "First Party: (Date)"
                  },
                  "signer_1": {
                    "type": "object",
                    "properties": {
                      "printed_name_and_capacity": {
                        "type": "string",
                        "description": "First Party: (*Authorized signature) / (Type or print name and capacity) \u2014 signer 1"
                      }
                    }
                  },
                  "signer_2": {
                    "type": "object",
                    "properties": {
                      "printed_name_and_capacity": {
                        "type": "string",
                        "description": "First Party: signer 2"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "merger"
  ]
}
