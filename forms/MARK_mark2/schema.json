{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/MARK_mark2.json",
  "title": "MARK_mark2 fill data",
  "type": "object",
  "properties": {
    "mark": {
      "type": "object",
      "properties": {
        "charter_number": {
          "type": "integer",
          "description": "Maine SOS-issued registration number for the original mark; recited (optionally) on a renewal application."
        },
        "type": {
          "type": "string",
          "description": "Free-text type-of-mark string (e.g., 'Trademark', 'Service Mark', 'Collective Mark', 'Combined'). Distinct from MARK_mark1's combined mark.type_and_class_number \u2014 this renewal form has separate TYPE (C) and CLASS (D) widgets."
        },
        "type_amended": {
          "type": "boolean",
          "description": "Boolean indicating whether the recited mark.type represents an amendment from the original registration (TYPE may be amended at renewal; TEXT and FEATURES may not)."
        },
        "text_words": {
          "type": "object",
          "properties": {
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            }
          }
        },
        "design_features": {
          "type": "object",
          "properties": {
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            }
          }
        },
        "usage_description": {
          "type": "object",
          "properties": {
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string"
            }
          }
        },
        "additional_pages_attached": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "applicant": {
          "type": "object",
          "properties": {
            "entity_name": {
              "type": "string"
            },
            "mailing_address": {
              "type": "string"
            },
            "entity_type": {
              "type": "string"
            },
            "entity_type_other_explanation": {
              "type": "string"
            },
            "jurisdiction_of_organization": {
              "type": "string"
            },
            "date_of_organization": {
              "type": "string"
            }
          }
        },
        "class_changes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "class_number": {
                "type": "string",
                "description": "D. CLASS NUMBER:"
              },
              "action": {
                "type": "string",
                "description": "D: For each NEW class added"
              },
              "description": {
                "type": "object",
                "properties": {
                  "line1": {
                    "type": "string",
                    "description": "D: DESCRIBE goods manufactured or sold and/or the service that is provided (line 1)"
                  },
                  "line2": {
                    "type": "string",
                    "description": "D: DESCRIBE goods/services (line 2)"
                  }
                }
              }
            }
          }
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "filing",
    "mark"
  ]
}
