{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/CORP_MBCA-17.json",
  "title": "CORP_MBCA-17 fill data",
  "type": "object",
  "properties": {
    "correction": {
      "type": "object",
      "properties": {
        "original_document_name": {
          "type": "string",
          "description": "Title of the original document being corrected (e.g., 'Articles of Incorporation', 'Articles of Amendment'). Already established in LLC_MLLC-17 \u2014 re-asserting here as the first business-corporation use."
        },
        "original_filing_date": {
          "type": "string",
          "description": "Date the original document being corrected was filed with the Secretary of State. Same key as LLC_MLLC-17."
        },
        "error_description": {
          "type": "string",
          "description": "Free-text description of the inaccuracy or defect (THIRD's recital lists the eligible defects: inaccurate record, defective execution, attestation, sealing, verification, acknowledgement, or electronic transmission). Same key as LLC_MLLC-17."
        },
        "corrected_information": {
          "type": "string",
          "description": "Free-text replacement for the portion of the original document being corrected. Replaces the original portion in its entirety. Same key as LLC_MLLC-17."
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "home_jurisdiction": {
          "type": "string"
        },
        "maine_authorization_date": {
          "type": "string"
        },
        "annual_report_reminder_email": {
          "type": "string"
        }
      }
    },
    "filing": {
      "type": "object",
      "properties": {
        "date_signed": {
          "type": "string"
        },
        "signer": {
          "type": "object",
          "properties": {
            "printed_name_and_capacity": {
              "type": "string"
            }
          }
        },
        "expedited_service": {
          "type": "object",
          "description": "Cover-letter expedited-service options (independent checkboxes).",
          "properties": {
            "hold_for_pickup": {
              "type": "boolean"
            },
            "expedite_24h": {
              "type": "boolean"
            },
            "immediate": {
              "type": "boolean"
            }
          }
        },
        "total_fees_dollars": {
          "type": "string"
        },
        "contact": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "attested_copy_recipient": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "firm": {
              "type": "string"
            },
            "mailing_address": {
              "type": "object",
              "properties": {
                "street": {
                  "type": "string"
                },
                "city_state_zip": {
                  "type": "string"
                }
              }
            }
          }
        },
        "entities": {
          "type": "array",
          "description": "Entity name(s) the filing covers, as listed on the cover block.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "correction",
    "entity",
    "filing"
  ]
}
