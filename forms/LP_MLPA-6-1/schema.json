{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maine-corporation-forms/schemas/LP_MLPA-6-1.json",
  "title": "LP_MLPA-6-1 fill data",
  "type": "object",
  "properties": {
    "filing": {
      "type": "object",
      "properties": {
        "accompanying_transaction_type": {
          "type": "string",
          "enum": [
            "entity_conversion_13c",
            "merger_or_share_exchange_13c",
            "inter_entity_consolidation_31",
            "conversion_31",
            "partnership_conversion_31"
          ]
        }
      }
    },
    "entity": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "designated_office": {
          "type": "object",
          "properties": {
            "physical_address": {
              "type": "string"
            },
            "mailing_address": {
              "type": "string"
            }
          }
        },
        "is_lllp": {
          "type": "boolean"
        },
        "is_professional_lllp": {
          "type": "boolean"
        },
        "professional_services_description": {
          "type": "string"
        },
        "additional_provisions_exhibit_letter": {
          "type": "string"
        }
      }
    },
    "registered_agent": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Whether the registered agent is a Commercial Registered Agent (CRA) or a Noncommercial Registered Agent. Enum: 'commercial' | 'noncommercial'.",
          "enum": [
            "commercial",
            "noncommercial"
          ]
        },
        "cra_public_number": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "physical_address": {
          "type": "string"
        },
        "mailing_address": {
          "type": "string"
        }
      }
    },
    "general_partner_1": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner_2": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner_3": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "general_partner": {
      "type": "object",
      "properties": {
        "additional_attached": {
          "type": "string"
        },
        "additional_exhibit_letter": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "entity",
    "filing",
    "registered_agent"
  ]
}
